<Application x:Class="OpenNDOF.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:OpenNDOF.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <conv:ConnectedSeverityConverter x:Key="ConnectedToSeverityConverter"/>
            <conv:BoolNegationConverter      x:Key="BoolNegConverter"/>
            <conv:MacroTypeNotNoneConverter  x:Key="MacroTypeNotNoneConverter"/>
            <BooleanToVisibilityConverter    x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
