<UserControl x:Class="OpenNDOF.App.Controls.AxisBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="Root"
             Height="28">

    <Grid DataContext="{Binding ElementName=Root}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="70"/>
        </Grid.ColumnDefinitions>

        <!-- Label -->
        <TextBlock Grid.Column="0"
                   Text="{Binding Label}"
                   VerticalAlignment="Center"
                   FontSize="12"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

        <!-- Bi-directional track -->
        <Grid Grid.Column="1"
              x:Name="TrackGrid"
              SizeChanged="TrackGrid_SizeChanged"
              VerticalAlignment="Center"
              Height="10"
              Margin="6,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>   <!-- negative side -->
                <ColumnDefinition Width="2"/>   <!-- centre divider -->
                <ColumnDefinition Width="*"/>   <!-- positive side -->
            </Grid.ColumnDefinitions>
            <!-- Background -->
            <Border Grid.ColumnSpan="3"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="5"/>
            <!-- Centre divider -->
            <Rectangle Grid.Column="1"
                       Fill="{DynamicResource TextFillColorSecondaryBrush}"/>
            <!-- Negative bar (right-aligned inside left column) -->
            <Rectangle x:Name="NegBar"
                       Grid.Column="0"
                       Width="0"
                       HorizontalAlignment="Right"
                       Fill="{Binding BarColor}"
                       Opacity="0.70"
                       RadiusX="4" RadiusY="4"/>
            <!-- Positive bar (left-aligned inside right column) -->
            <Rectangle x:Name="PosBar"
                       Grid.Column="2"
                       Width="0"
                       HorizontalAlignment="Left"
                       Fill="{Binding BarColor}"
                       RadiusX="4" RadiusY="4"/>
        </Grid>

        <!-- Numeric value -->
        <TextBlock Grid.Column="2"
                   Text="{Binding DisplayText}"
                   VerticalAlignment="Center"
                   TextAlignment="Right"
                   FontFamily="Consolas"
                   FontSize="12"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
    </Grid>
</UserControl>
