<UserControl x:Class="OpenNDOF.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ctrl="clr-namespace:OpenNDOF.App.Controls"
             xmlns:vm="clr-namespace:OpenNDOF.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16" MaxWidth="900">

            <!-- Page header -->
            <TextBlock Text="Dashboard"
                       Style="{StaticResource TitleLargeTextBlockStyle}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Device status and live sensor readout"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,20"/>

            <!-- Status info bar -->
            <ui:InfoBar IsOpen="True"
                        IsClosable="False"
                        Severity="{Binding IsConnected, Converter={StaticResource ConnectedToSeverityConverter}}"
                        Title="{Binding StatusMessage}"
                        Margin="0,0,0,16"/>

            <!-- Device info + connect actions -->
            <ui:Card Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <ui:SymbolIcon Symbol="UsbPlug24" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding DeviceName}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding DeviceType, StringFormat='Type: {0}'}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding ActiveProfile, StringFormat='Profile: {0}'}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:Button Content="Connect"
                                   Icon="{ui:SymbolIcon PlugConnected24}"
                                   Appearance="Primary"
                                   Command="{Binding ConnectCommand}"
                                   IsEnabled="{Binding IsConnected, Converter={StaticResource BoolNegConverter}}"
                                   Margin="0,0,8,0"/>
                        <ui:Button Content="Disconnect"
                                   Icon="{ui:SymbolIcon PlugDisconnected24}"
                                   Command="{Binding DisconnectCommand}"
                                   IsEnabled="{Binding IsConnected}"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Sensor readout -->
            <TextBlock Text="Live Sensor Values"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,0,0,8"/>

            <!-- Translation axes -->
            <ui:Card Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Translation"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,0,0,10"/>
                    <ctrl:AxisBar Label="TX  (Right/Left)" Value="{Binding Tx}" DisplayText="{Binding TxLabel}"
                                  BarColor="#FF4CAF50"/>
                    <ctrl:AxisBar Label="TY  (Up/Down)"    Value="{Binding Ty}" DisplayText="{Binding TyLabel}"
                                  BarColor="#FF2196F3"/>
                    <ctrl:AxisBar Label="TZ  (Fwd/Back)"   Value="{Binding Tz}" DisplayText="{Binding TzLabel}"
                                  BarColor="#FFFF9800"/>
                </StackPanel>
            </ui:Card>

            <!-- Rotation axes -->
            <ui:Card Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Rotation"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,0,0,10"/>
                    <ctrl:AxisBar Label="RX  (Pitch)" Value="{Binding Rx}" DisplayText="{Binding RxLabel}"
                                  BarColor="#FFE91E63"/>
                    <ctrl:AxisBar Label="RY  (Yaw)"   Value="{Binding Ry}" DisplayText="{Binding RyLabel}"
                                  BarColor="#FF9C27B0"/>
                    <ctrl:AxisBar Label="RZ  (Roll)"  Value="{Binding Rz}" DisplayText="{Binding RzLabel}"
                                  BarColor="#FF00BCD4"/>
                </StackPanel>
            </ui:Card>

            <!-- Button state -->
            <ui:Card>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Keyboard24" Margin="0,0,10,0"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Pressed buttons: " FontWeight="SemiBold"/>
                        <Run Text="{Binding PressedButtons}"/>
                    </TextBlock>
                </StackPanel>
            </ui:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
